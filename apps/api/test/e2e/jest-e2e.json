{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "testEnvironment": "node",
  "testTimeout": 30000,
  "testRegex": "test/e2e/specs/.+\\.e2e-spec\\.ts$",
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/test/e2e/mocks/uuid.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
