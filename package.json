{
  "name": "logisync",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev --filter=@logisync/api --filter=@logisync/web",
    "dev:api": "turbo dev --filter @logisync/api",
    "dev:web": "turbo dev --filter @logisync/web",
    "dev:mobile": "pnpm --filter @logisync/mobile dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:studio": "turbo db:studio --filter=@logisync/api",
    "db:setup": "turbo db:setup --filter=@logisync/api",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:fast && pnpm lint:deep",
    "lint:fast": "biome check --apply .",
    "lint:deep": "turbo lint",
    "format": "biome format --write .",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "biome": "^0.3.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.8.20"
  }
}
